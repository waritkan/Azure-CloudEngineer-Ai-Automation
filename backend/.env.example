# Azure AI Automation - Environment Variables
# Copy this file to .env and fill in your values

# ====================
# Application Settings
# ====================
DEBUG=true
APP_NAME="Azure AI Automation"

# ====================
# Azure Credentials
# ====================
# Get these from Azure Portal > App Registrations
# Tutorial: https://learn.microsoft.com/en-us/azure/active-directory/develop/quickstart-register-app

AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Azure Settings
AZURE_RESOURCE_GROUP=rg-ai-automation
AZURE_REGION=southeastasia

# ====================
# AI Configuration (OpenRouter)
# ====================
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here

# OpenRouter Base URL (don't change this)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model to use - Available models at https://openrouter.ai/models
# Recommended options:
# - openai/gpt-4-turbo (most capable, ~$0.01/1K tokens)
# - openai/gpt-3.5-turbo (faster, cheaper, ~$0.0005/1K tokens)
# - anthropic/claude-3.5-sonnet (excellent, ~$0.003/1K tokens)
# - google/gemini-pro (free tier available!)
OPENAI_MODEL=openai/gpt-4-turbo

# Optional: Your app info (for OpenRouter analytics)
APP_URL=https://github.com/your-username/azure-ai-automation
APP_TITLE=Azure AI Automation

# ====================
# Budget Control
# ====================
# Maximum monthly budget in USD
MONTHLY_BUDGET_LIMIT=10.0

# Enable mock mode (true = simulation, false = real Azure)
# ALWAYS start with true until you've tested everything!
ENABLE_MOCK_MODE=true

# ====================
# Quick Start Guide
# ====================
#
# 1. MOCK MODE (No Azure needed):
#    - Set ENABLE_MOCK_MODE=true
#    - Set OPENAI_API_KEY
#    - Leave Azure settings empty
#    - Run: uvicorn app.main:app --reload
#
# 2. AZURE MODE (Real operations):
#    - Create Azure account
#    - Create App Registration
#    - Fill in all AZURE_* values
#    - Set ENABLE_MOCK_MODE=false
#    - Test in mock mode first!
#
# ====================
# Security Notes
# ====================
# - NEVER commit this file to git
# - Add .env to .gitignore
# - Rotate secrets regularly
# - Use Azure Key Vault in production
